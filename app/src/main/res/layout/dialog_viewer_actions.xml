<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp"
    android:background="?attr/svColorCard">

    <TextView
        android:id="@+id/actionsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:text="@string/viewer_actions_title_simple"
        android:textColor="?attr/svColorTextPrimary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/actionEditButton"
        style="?attr/materialButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="@string/viewer_action_edit"
        android:textColor="?attr/svColorOnPrimary"
        android:backgroundTint="?attr/svColorPrimary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/actionExportButton"
        style="?attr/materialButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="@string/viewer_action_export"
        android:textColor="?attr/svColorOnPrimary"
        android:backgroundTint="?attr/svColorPrimary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/actionShareButton"
        style="?attr/materialButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="@string/viewer_action_share"
        android:textColor="?attr/svColorOnPrimary"
        android:backgroundTint="?attr/svColorPrimary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/actionDeleteButton"
        style="?attr/materialButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/viewer_action_delete"
        android:textColor="?attr/svColorOnSecondary"
        android:backgroundTint="?attr/svColorAccent" />

</LinearLayout>
