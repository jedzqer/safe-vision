<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page_gradient"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingLeft="16dp"
    android:paddingTop="16dp"
    android:paddingRight="16dp"
    android:paddingBottom="24dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/previewCard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true"
            app:strokeColor="?attr/svColorBorder"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintDimensionRatio="1:1">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/imagePreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/svColorSurfaceVariant"
                    android:contentDescription="@string/preview_content_description"
                    android:scaleType="centerCrop" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/batchResultsRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/svColorSurfaceVariant"
                    android:padding="8dp"
                    android:visibility="gone" />
            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/status_placeholder"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textAlignment="center"
            android:textColor="?attr/svColorTextSecondary"
            app:layout_constraintTop_toBottomOf="@id/previewCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="12dp"
            android:layout_marginTop="10dp"
            android:max="100"
            android:progress="0"
            android:progressTint="?attr/svColorAccent"
            android:progressBackgroundTint="?attr/svColorBorder"
            app:layout_constraintTop_toBottomOf="@id/txtStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectImage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="4dp"
            android:text="@string/action_select_image"
            android:backgroundTint="?attr/svColorPrimary"
            android:textColor="?attr/svColorOnPrimary"
            app:layout_constraintTop_toBottomOf="@id/progressBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnSelectVideo" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectVideo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="@string/action_select_video"
            android:backgroundTint="?attr/svColorPrimaryVariant"
            android:textColor="?attr/svColorOnPrimary"
            app:layout_constraintTop_toBottomOf="@id/progressBar"
            app:layout_constraintStart_toEndOf="@id/btnSelectImage"
            app:layout_constraintEnd_toStartOf="@id/btnSelectFolder" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectFolder"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="4dp"
            android:text="@string/action_select_folder"
            android:backgroundTint="?attr/svColorPrimary"
            android:textColor="?attr/svColorOnPrimary"
            app:layout_constraintTop_toBottomOf="@id/progressBar"
            app:layout_constraintStart_toEndOf="@id/btnSelectVideo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_chainStyle="spread" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRunModel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/action_run_detection"
            android:backgroundTint="?attr/svColorAccent"
            android:textColor="?attr/svColorOnSecondary"
            app:layout_constraintTop_toBottomOf="@id/btnSelectFolder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Switch
            android:id="@+id/switchAnimeModel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/action_use_anime_model"
            android:textColor="?attr/svColorTextPrimary"
            android:thumbTint="?attr/svColorPrimary"
            android:trackTint="@color/switch_track_tint"
            app:layout_constraintTop_toBottomOf="@id/btnRunModel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Switch
            android:id="@+id/switchVideoHighLoad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/action_video_high_load"
            android:textColor="?attr/svColorTextPrimary"
            android:thumbTint="?attr/svColorPrimary"
            android:trackTint="@color/switch_track_tint"
            app:layout_constraintTop_toBottomOf="@id/switchAnimeModel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScreenDetection"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:text="@string/action_start_screen_detection"
            android:textColor="?attr/svColorPrimary"
            app:strokeColor="?attr/svColorPrimary"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/switchVideoHighLoad"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/debugToggle"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/settings_debug_info"
            android:textSize="12sp"
            android:textColor="?attr/svColorPrimary"
            app:strokeColor="?attr/svColorPrimary"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/btnScreenDetection"
            app:layout_constraintBottom_toTopOf="@id/debugContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/debugContainer"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card_surface"
            android:padding="10dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/debugToggle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ScrollView
                android:id="@+id/debugScrollView"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="?attr/svColorSurfaceVariant"
                android:padding="6dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/copyDebugButton"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/debugTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="?attr/svColorTextPrimary"
                    android:textSize="10sp"
                    android:textIsSelectable="true" />

            </ScrollView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/copyDebugButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/common_copy"
                android:textSize="12sp"
                android:textColor="?attr/svColorPrimary"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/clearDebugButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/common_clear"
                android:textSize="12sp"
                android:textColor="?attr/svColorPrimaryVariant"
                app:layout_constraintTop_toBottomOf="@id/copyDebugButton"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
