<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="?attr/svColorCard"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp"
    app:cardUseCompatPadding="true"
    app:strokeColor="?attr/svColorBorder"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/folderSelectIndicator"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_output_indicator_ring"
                android:visibility="gone">

                <View
                    android:id="@+id/folderSelectDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_output_indicator_dot"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/folderTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:textColor="?attr/svColorTextPrimary"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/openFolderButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_action_circle"
                android:contentDescription="@string/gallery_open_folder"
                android:padding="8dp"
                android:src="@drawable/ic_page_next"
                android:tint="?attr/svColorAccent" />
        </LinearLayout>

        <TextView
            android:id="@+id/folderCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:textAppearance="?attr/textAppearanceBody2"
            android:textColor="?attr/svColorTextSecondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/folderPreview1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/svColorSurfaceVariant"
                android:scaleType="centerCrop" />

            <View
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <ImageView
                android:id="@+id/folderPreview2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/svColorSurfaceVariant"
                android:scaleType="centerCrop" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
