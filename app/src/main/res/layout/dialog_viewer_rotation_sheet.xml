<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/svColorCard"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/rotationTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/viewer_edit_rotate_title"
        android:textColor="?attr/svColorTextPrimary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/rotationValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_horizontal"
        android:textColor="?attr/svColorTextSecondary"
        android:textSize="14sp" />

    <com.google.android.material.slider.Slider
        android:id="@+id/rotationSlider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:valueFrom="-180"
        android:valueTo="180"
        android:stepSize="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/rotationCancelButton"
            style="?attr/materialButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@android:string/cancel"
            android:textColor="?attr/svColorTextPrimary"
            android:backgroundTint="?attr/svColorChip" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/rotationApplyButton"
            style="?attr/materialButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@android:string/ok"
            android:textColor="?attr/svColorOnPrimary"
            android:backgroundTint="?attr/svColorPrimary" />
    </LinearLayout>

</LinearLayout>
