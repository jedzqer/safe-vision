<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="?attr/svColorCard"
    app:strokeColor="?attr/svColorBorder"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/imageThumbnail"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="?attr/svColorSurfaceVariant"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintDimensionRatio="1:1" />

        <TextView
            android:id="@+id/mediaBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@drawable/bg_card_surface"
            android:paddingStart="6dp"
            android:paddingTop="2dp"
            android:paddingEnd="6dp"
            android:paddingBottom="2dp"
            android:textAppearance="?attr/textAppearanceCaption"
            android:textColor="?attr/svColorTextPrimary"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/imageThumbnail"
            app:layout_constraintStart_toStartOf="@id/imageThumbnail" />

        <View
            android:id="@+id/selectionOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#33000000"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/imageThumbnail"
            app:layout_constraintBottom_toBottomOf="@id/imageThumbnail"
            app:layout_constraintStart_toStartOf="@id/imageThumbnail"
            app:layout_constraintEnd_toEndOf="@id/imageThumbnail" />

        <CheckBox
            android:id="@+id/selectionCheck"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="6dp"
            android:buttonTint="?attr/svColorAccent"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/imageThumbnail"
            app:layout_constraintEnd_toEndOf="@id/imageThumbnail" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
